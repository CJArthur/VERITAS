# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# При запуске через docker-compose: DB_HOST=db  (имя сервиса в compose)
# При локальном запуске без Docker: DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=veritas_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Вариант 1 — локальная разработка / Railway Redis plugin:
#   UPSTASH_REDIS_URL=redis://localhost:6379  (или Railway даст свой URL)
#   UPSTASH_REDIS_TOKEN=  (оставить пустым)
# Вариант 2 — Upstash (serverless, бесплатный тир):
#   взять URL и TOKEN из консоли upstash.com
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=replace_me_with_32_plus_char_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Cookies ──────────────────────────────────────────────────────────────────
# False — локальная разработка (http), True — продакшн (https)
SECURE_COOKIES=False

# ─── Верификация Email ────────────────────────────────────────────────────────
#
# SKIP_EMAIL_VERIFICATION — управляет режимом подтверждения аккаунта при регистрации.
#
# false (по умолчанию, рекомендуется для продакшна):
#   Стандартный флоу — после регистрации пользователь получает письмо
#   со ссылкой подтверждения. Аккаунт активируется только после перехода по ней.
#
# true (для окружений без исходящего SMTP, например Railway):
#   Аккаунт активируется сразу при регистрации, письмо не отправляется.
#   Используйте только во время разработки или демо-деплоя.
#   ВАЖНО: перед выходом в прод установите false и настройте SMTP ниже.
#
SKIP_EMAIL_VERIFICATION=false

# ─── SMTP ─────────────────────────────────────────────────────────────────────
# Используется только если SKIP_EMAIL_VERIFICATION=false.
# Gmail: порт 465 + SSL=True + TLS=False, пароль — "Пароль приложения" из настроек Google.
# Yandex: порт 587 + TLS=True + SSL=False, пароль — пароль от аккаунта.
# Внимание: Railway и ряд других платформ блокируют исходящий SMTP (порты 25/465/587).
# В таком случае используйте SKIP_EMAIL_VERIFICATION=true или смените хостинг.
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=your@email.com
MAIL_FROM_NAME=VERITAS
MAIL_TLS=True
MAIL_SSL=False

# ─── URL-адреса ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BASE_VERIFICATION_URL=http://localhost:8200/api/v1/verify
BASE_FORGOT_PASSWORD_URL=http://localhost:8200/api/v1/reset-pass
FORGOT_PASSWORD_FRONTEND_URL=http://localhost:3000/reset-password
ALLOWED_ORIGINS=http://localhost:3000
PUBLIC_DIPLOMA_URL_BASE=http://localhost:8200/api/v1/public/diplomas

# ─── Токены верификации ───────────────────────────────────────────────────────
VERIFICATION_URL_EXPIRY_SECONDS=1800
FORGOT_PASSWORD_URL_EXPIRY_SECONDS=1800

# ─── Bootstrap суперадмина ────────────────────────────────────────────────────
# Первая регистрация с этим email получит роль super_admin (только пока таблица пуста)
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ─── Docker ───────────────────────────────────────────────────────────────────
FASTAPI_PORT=8200

# ─── Примечание для фронтенда (frontend/.env.local или Vercel) ────────────────
# Раздельный деплой (Vercel + Railway):
#   NEXT_PUBLIC_API_URL=/api/proxy   ← клиентские запросы через встроенный прокси
#   API_URL=https://your-backend.up.railway.app  ← middleware/SSR напрямую
#
# Единый сервер (продакшн):
#   NEXT_PUBLIC_API_URL=https://api.your-domain.com  ← напрямую, прокси не нужен
#   API_URL=https://api.your-domain.com
#   Файл frontend/app/api/proxy/[...path]/route.ts можно удалить.
