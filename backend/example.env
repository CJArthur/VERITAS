# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# При запуске через docker-compose: DB_HOST=db  (имя сервиса в compose)
# При локальном запуске без Docker: DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=veritas_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Вариант 1 — локальная разработка / Railway Redis plugin:
#   UPSTASH_REDIS_URL=redis://localhost:6379  (или Railway даст свой URL)
#   UPSTASH_REDIS_TOKEN=  (оставить пустым)
# Вариант 2 — Upstash (serverless, бесплатный тир):
#   взять URL и TOKEN из консоли upstash.com
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=replace_me_with_32_plus_char_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Cookies ──────────────────────────────────────────────────────────────────
# False — локальная разработка (http), True — продакшн (https)
SECURE_COOKIES=False

# ─── SMTP ─────────────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=your@email.com
MAIL_FROM_NAME=VERITAS
MAIL_TLS=True
MAIL_SSL=False

# ─── URL-адреса ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BASE_VERIFICATION_URL=http://localhost:8200/api/v1/verify
BASE_FORGOT_PASSWORD_URL=http://localhost:8200/api/v1/reset-pass
FORGOT_PASSWORD_FRONTEND_URL=http://localhost:3000/reset-password
ALLOWED_ORIGINS=http://localhost:3000
PUBLIC_DIPLOMA_URL_BASE=http://localhost:8200/api/v1/public/diplomas

# ─── Токены верификации ───────────────────────────────────────────────────────
VERIFICATION_URL_EXPIRY_SECONDS=1800
FORGOT_PASSWORD_URL_EXPIRY_SECONDS=1800

# ─── Bootstrap суперадмина ────────────────────────────────────────────────────
# Первая регистрация с этим email получит роль super_admin (только пока таблица пуста)
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ─── Docker ───────────────────────────────────────────────────────────────────
FASTAPI_PORT=8200
